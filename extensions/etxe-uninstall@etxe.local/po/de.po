msgid "Application"
msgstr "Anwendung"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "\"%s\" deinstallieren?"

msgid "This will remove the app from this computer."
msgstr "Dadurch wird die App von diesem Computer entfernt."

msgid "Your personal files will not be deleted."
msgstr "Ihre persönlichen Dateien werden nicht gelöscht."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "\"%s\" kann nicht deinstalliert werden"

msgid "OK"
msgstr "OK"

msgid "This is a protected GNOME system application."
msgstr "Dies ist eine geschützte GNOME-Systemanwendung."

msgid "Cannot uninstall application"
msgstr "Anwendung kann nicht deinstalliert werden"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "Es konnte nicht festgestellt werden, ob dieser Starter zu einem Flatpak- oder pacman-Paket gehört."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "Das Paket %s ist geschützt, da seine Entfernung die Arbeitsumgebung oder die Paketverwaltung beschädigen kann."

msgid "Required uninstall tool is not installed."
msgstr "Das erforderliche Deinstallationswerkzeug ist nicht installiert."

msgid "Uninstalling application"
msgstr "Anwendung wird deinstalliert"

#, javascript-format
msgid "Removing %s..."
msgstr "%s wird entfernt..."

msgid "Application uninstalled"
msgstr "Anwendung deinstalliert"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s wurde erfolgreich entfernt."

msgid "The uninstall command failed."
msgstr "Der Deinstallationsbefehl ist fehlgeschlagen."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "%s konnte nicht deinstalliert werden"

msgid "protected"
msgstr "geschützt"
