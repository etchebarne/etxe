msgid "Application"
msgstr "अनुप्रयोग"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "\"%s\" को अनइंस्टॉल करें?"

msgid "This will remove the app from this computer."
msgstr "यह ऐप को इस कंप्यूटर से हटा देगा।"

msgid "Your personal files will not be deleted."
msgstr "आपकी व्यक्तिगत फ़ाइलें नहीं हटाई जाएँगी।"

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "\"%s\" को अनइंस्टॉल नहीं किया जा सकता"

msgid "OK"
msgstr "ठीक है"

msgid "This is a protected GNOME system application."
msgstr "यह एक सुरक्षित GNOME सिस्टम अनुप्रयोग है।"

msgid "Cannot uninstall application"
msgstr "अनुप्रयोग अनइंस्टॉल नहीं किया जा सकता"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "यह निर्धारित नहीं किया जा सका कि यह लॉन्चर Flatpak या pacman पैकेज से संबंधित है या नहीं।"

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "पैकेज %s सुरक्षित है क्योंकि इसे हटाने से डेस्कटॉप या पैकेज प्रबंधक खराब हो सकता है।"

msgid "Required uninstall tool is not installed."
msgstr "आवश्यक अनइंस्टॉल उपकरण स्थापित नहीं है।"

msgid "Uninstalling application"
msgstr "अनुप्रयोग अनइंस्टॉल किया जा रहा है"

#, javascript-format
msgid "Removing %s..."
msgstr "%s हटाया जा रहा है..."

msgid "Application uninstalled"
msgstr "अनुप्रयोग अनइंस्टॉल हो गया"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s सफलतापूर्वक हटा दिया गया।"

msgid "The uninstall command failed."
msgstr "अनइंस्टॉल कमांड विफल रही।"

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "%s को अनइंस्टॉल करने में विफल"

msgid "protected"
msgstr "सुरक्षित"
