msgid "Application"
msgstr "अनुप्रयोग"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "\"%s\" विस्थापित करायचे?"

msgid "This will remove the app from this computer."
msgstr "यामुळे हे अॅप या संगणकावरून काढले जाईल."

msgid "Your personal files will not be deleted."
msgstr "आपल्या वैयक्तिक फाइल्स हटवल्या जाणार नाहीत."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "\"%s\" विस्थापित करता येत नाही"

msgid "OK"
msgstr "ठीक आहे"

msgid "This is a protected GNOME system application."
msgstr "हा संरक्षित GNOME प्रणाली अनुप्रयोग आहे."

msgid "Cannot uninstall application"
msgstr "अनुप्रयोग विस्थापित करता येत नाही"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "हा लाँचर Flatpak किंवा pacman पॅकेजशी संबंधित आहे का हे ठरवता आले नाही."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "पॅकेज %s संरक्षित आहे कारण ते काढल्यास डेस्कटॉप किंवा पॅकेज व्यवस्थापक बिघडू शकतो."

msgid "Required uninstall tool is not installed."
msgstr "आवश्यक विस्थापन साधन स्थापित नाही."

msgid "Uninstalling application"
msgstr "अनुप्रयोग विस्थापित होत आहे"

#, javascript-format
msgid "Removing %s..."
msgstr "%s काढले जात आहे..."

msgid "Application uninstalled"
msgstr "अनुप्रयोग विस्थापित झाला"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s यशस्वीरित्या काढले गेले."

msgid "The uninstall command failed."
msgstr "विस्थापन आदेश अयशस्वी झाला."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "%s विस्थापित करण्यात अयशस्वी"

msgid "protected"
msgstr "संरक्षित"
