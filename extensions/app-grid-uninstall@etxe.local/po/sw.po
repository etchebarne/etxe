msgid "Application"
msgstr "Programu"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "Sanidua \"%s\"?"

msgid "This will remove the app from this computer."
msgstr "Hii itaondoa programu kwenye kompyuta hii."

msgid "Your personal files will not be deleted."
msgstr "Faili zako binafsi hazitafutwa."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "Haiwezi kusanidua \"%s\""

msgid "OK"
msgstr "Sawa"

msgid "This is a protected GNOME system application."
msgstr "Hii ni programu ya mfumo wa GNOME iliyolindwa."

msgid "Cannot uninstall application"
msgstr "Haiwezi kusanidua programu"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "Haikuwezekana kubaini kama kizinduzi hiki ni cha kifurushi cha Flatpak au pacman."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "Kifurushi %s kinalindwa kwa sababu kukiondoa kunaweza kuharibu eneo-kazi au kidhibiti vifurushi."

msgid "Required uninstall tool is not installed."
msgstr "Zana inayohitajika ya kusanidua haijasakinishwa."

msgid "Uninstalling application"
msgstr "Inasanidua programu"

#, javascript-format
msgid "Removing %s..."
msgstr "Inaondoa %s..."

msgid "Application uninstalled"
msgstr "Programu imesaniduliwa"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s imeondolewa kwa mafanikio."

msgid "The uninstall command failed."
msgstr "Amri ya kusanidua imeshindwa."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "Imeshindwa kusanidua %s"

msgid "protected"
msgstr "imelindwa"
