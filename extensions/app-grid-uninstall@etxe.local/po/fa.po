msgid "Application"
msgstr "برنامه"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "\"%s\" حذف نصب شود؟"

msgid "This will remove the app from this computer."
msgstr "این کار برنامه را از این رایانه حذف می‌کند."

msgid "Your personal files will not be deleted."
msgstr "پرونده‌های شخصی شما حذف نخواهند شد."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "نمی‌توان \"%s\" را حذف نصب کرد"

msgid "OK"
msgstr "تأیید"

msgid "This is a protected GNOME system application."
msgstr "این یک برنامهٔ سیستمی محافظت‌شدهٔ GNOME است."

msgid "Cannot uninstall application"
msgstr "نمی‌توان برنامه را حذف نصب کرد"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "نمی‌توان تشخیص داد که این اجراگر به یک بستهٔ Flatpak یا pacman تعلق دارد یا نه."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "بستهٔ %s محافظت‌شده است، زیرا حذف آن می‌تواند میزکار یا مدیر بسته را خراب کند."

msgid "Required uninstall tool is not installed."
msgstr "ابزار لازم برای حذف نصب، نصب نشده است."

msgid "Uninstalling application"
msgstr "در حال حذف نصب برنامه"

#, javascript-format
msgid "Removing %s..."
msgstr "در حال حذف %s..."

msgid "Application uninstalled"
msgstr "برنامه حذف نصب شد"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s با موفقیت حذف شد."

msgid "The uninstall command failed."
msgstr "فرمان حذف نصب ناموفق بود."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "حذف نصب %s ناموفق بود"

msgid "protected"
msgstr "محافظت‌شده"
