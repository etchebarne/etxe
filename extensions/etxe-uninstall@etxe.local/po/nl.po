msgid "Application"
msgstr "Toepassing"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "\"%s\" verwijderen?"

msgid "This will remove the app from this computer."
msgstr "Hiermee wordt de app van deze computer verwijderd."

msgid "Your personal files will not be deleted."
msgstr "Uw persoonlijke bestanden worden niet verwijderd."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "Kan \"%s\" niet verwijderen"

msgid "OK"
msgstr "OK"

msgid "This is a protected GNOME system application."
msgstr "Dit is een beschermde GNOME-systeemtoepassing."

msgid "Cannot uninstall application"
msgstr "Kan toepassing niet verwijderen"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "Kan niet bepalen of deze starter bij een Flatpak- of pacman-pakket hoort."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "Pakket %s is beschermd omdat verwijderen het bureaublad of pakketbeheer kan beschadigen."

msgid "Required uninstall tool is not installed."
msgstr "Het vereiste verwijderhulpmiddel is niet geïnstalleerd."

msgid "Uninstalling application"
msgstr "Toepassing verwijderen"

#, javascript-format
msgid "Removing %s..."
msgstr "%s verwijderen..."

msgid "Application uninstalled"
msgstr "Toepassing verwijderd"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s is succesvol verwijderd."

msgid "The uninstall command failed."
msgstr "De verwijderopdracht is mislukt."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "Kan %s niet verwijderen"

msgid "protected"
msgstr "beschermd"
