msgid "Application"
msgstr "Aplicație"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "Dezinstalați „%s”?"

msgid "This will remove the app from this computer."
msgstr "Aceasta va elimina aplicația de pe acest computer."

msgid "Your personal files will not be deleted."
msgstr "Fișierele dvs. personale nu vor fi șterse."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "Nu se poate dezinstala „%s”"

msgid "OK"
msgstr "OK"

msgid "This is a protected GNOME system application."
msgstr "Aceasta este o aplicație de sistem GNOME protejată."

msgid "Cannot uninstall application"
msgstr "Nu se poate dezinstala aplicația"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "Nu s-a putut determina dacă acest lansator aparține unui pachet Flatpak sau pacman."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "Pachetul %s este protejat deoarece eliminarea lui poate afecta mediul desktop sau administratorul de pachete."

msgid "Required uninstall tool is not installed."
msgstr "Instrumentul de dezinstalare necesar nu este instalat."

msgid "Uninstalling application"
msgstr "Se dezinstalează aplicația"

#, javascript-format
msgid "Removing %s..."
msgstr "Se elimină %s..."

msgid "Application uninstalled"
msgstr "Aplicație dezinstalată"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s a fost eliminat cu succes."

msgid "The uninstall command failed."
msgstr "Comanda de dezinstalare a eșuat."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "Nu s-a reușit dezinstalarea %s"

msgid "protected"
msgstr "protejat"
