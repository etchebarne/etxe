msgid "Application"
msgstr "பயன்பாடு"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "\"%s\" ஐ நிறுவல் நீக்கவா?"

msgid "This will remove the app from this computer."
msgstr "இது இந்த கணினியில் இருந்து பயன்பாட்டை அகற்றும்."

msgid "Your personal files will not be deleted."
msgstr "உங்கள் தனிப்பட்ட கோப்புகள் நீக்கப்படாது."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "\"%s\" ஐ நிறுவல் நீக்க முடியாது"

msgid "OK"
msgstr "சரி"

msgid "This is a protected GNOME system application."
msgstr "இது பாதுகாக்கப்பட்ட GNOME கணினி பயன்பாடு."

msgid "Cannot uninstall application"
msgstr "பயன்பாட்டை நிறுவல் நீக்க முடியாது"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "இந்த துவக்கி Flatpak அல்லது pacman தொகுப்புக்குச் சேர்ந்ததா என்பதை தீர்மானிக்க முடியவில்லை."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "%s தொகுப்பு பாதுகாக்கப்பட்டுள்ளது, ஏனெனில் அதை அகற்றுவது மேசைத்தளத்தையோ தொகுப்பு மேலாளரையோ பாதிக்கலாம்."

msgid "Required uninstall tool is not installed."
msgstr "தேவையான நிறுவல் நீக்க கருவி நிறுவப்படவில்லை."

msgid "Uninstalling application"
msgstr "பயன்பாடு நிறுவல் நீக்கப்படுகிறது"

#, javascript-format
msgid "Removing %s..."
msgstr "%s அகற்றப்படுகிறது..."

msgid "Application uninstalled"
msgstr "பயன்பாடு நிறுவல் நீக்கப்பட்டது"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s வெற்றிகரமாக அகற்றப்பட்டது."

msgid "The uninstall command failed."
msgstr "நிறுவல் நீக்க கட்டளை தோல்வியடைந்தது."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "%s ஐ நிறுவல் நீக்க முடியவில்லை"

msgid "protected"
msgstr "பாதுகாக்கப்பட்டது"
