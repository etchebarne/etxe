msgid "Application"
msgstr "Ứng dụng"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "Gỡ cài đặt \"%s\"?"

msgid "This will remove the app from this computer."
msgstr "Thao tác này sẽ xóa ứng dụng khỏi máy tính này."

msgid "Your personal files will not be deleted."
msgstr "Các tệp cá nhân của bạn sẽ không bị xóa."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "Không thể gỡ cài đặt \"%s\""

msgid "OK"
msgstr "OK"

msgid "This is a protected GNOME system application."
msgstr "Đây là một ứng dụng hệ thống GNOME được bảo vệ."

msgid "Cannot uninstall application"
msgstr "Không thể gỡ cài đặt ứng dụng"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "Không thể xác định trình khởi chạy này thuộc về gói Flatpak hay pacman."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "Gói %s được bảo vệ vì việc xóa nó có thể làm hỏng màn hình nền hoặc trình quản lý gói."

msgid "Required uninstall tool is not installed."
msgstr "Công cụ gỡ cài đặt cần thiết chưa được cài đặt."

msgid "Uninstalling application"
msgstr "Đang gỡ cài đặt ứng dụng"

#, javascript-format
msgid "Removing %s..."
msgstr "Đang xóa %s..."

msgid "Application uninstalled"
msgstr "Ứng dụng đã được gỡ cài đặt"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s đã được xóa thành công."

msgid "The uninstall command failed."
msgstr "Lệnh gỡ cài đặt đã thất bại."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "Không thể gỡ cài đặt %s"

msgid "protected"
msgstr "được bảo vệ"
