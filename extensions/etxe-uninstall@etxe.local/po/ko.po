msgid "Application"
msgstr "애플리케이션"

#, javascript-format
msgid "Uninstall \"%s\"?"
msgstr "\"%s\"을(를) 제거하시겠습니까?"

msgid "This will remove the app from this computer."
msgstr "이 앱을 이 컴퓨터에서 제거합니다."

msgid "Your personal files will not be deleted."
msgstr "개인 파일은 삭제되지 않습니다."

#, javascript-format
msgid "Cannot uninstall \"%s\""
msgstr "\"%s\"을(를) 제거할 수 없습니다"

msgid "OK"
msgstr "확인"

msgid "This is a protected GNOME system application."
msgstr "보호된 GNOME 시스템 애플리케이션입니다."

msgid "Cannot uninstall application"
msgstr "애플리케이션을 제거할 수 없습니다"

msgid "Could not determine whether this launcher belongs to a Flatpak or pacman package."
msgstr "이 실행기가 Flatpak 또는 pacman 패키지에 속하는지 확인할 수 없습니다."

#, javascript-format
msgid "Package %s is protected because removing it can break the desktop or package manager."
msgstr "패키지 %s은(는) 제거하면 데스크톱 또는 패키지 관리자가 손상될 수 있어 보호됩니다."

msgid "Required uninstall tool is not installed."
msgstr "필요한 제거 도구가 설치되어 있지 않습니다."

msgid "Uninstalling application"
msgstr "애플리케이션 제거 중"

#, javascript-format
msgid "Removing %s..."
msgstr "%s 제거 중..."

msgid "Application uninstalled"
msgstr "애플리케이션 제거됨"

#, javascript-format
msgid "%s was removed successfully."
msgstr "%s이(가) 성공적으로 제거되었습니다."

msgid "The uninstall command failed."
msgstr "제거 명령이 실패했습니다."

#, javascript-format
msgid "Failed to uninstall %s"
msgstr "%s 제거 실패"

msgid "protected"
msgstr "보호됨"
